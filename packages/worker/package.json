{
  "name": "@radar/worker",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "generate:config": "node ../../scripts/generate-config-snapshot.mjs",
    "dev": "wrangler dev",
    "dev:local": "tsx src/local-server.ts",
    "deploy": "npm run generate:config && wrangler d1 migrations apply adtech-change-radar --remote && wrangler deploy --keep-vars",
    "build": "npm run generate:config && wrangler deploy --dry-run --outdir dist",
    "lint": "tsc --noEmit",
    "typecheck": "tsc --noEmit",
    "test": "npm run generate:config && vitest run"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20260220.0",
    "@types/node": "^20.17.57",
    "@types/better-sqlite3": "^7.6.12",
    "better-sqlite3": "^11.10.0",
    "tsx": "^4.20.5",
    "typescript": "^5.7.3",
    "vitest": "^3.2.4"
  },
  "dependencies": {
    "ajv": "^8.17.1",
    "cheerio": "^1.1.2",
    "diff": "^8.0.2",
    "fast-xml-parser": "^5.2.5",
    "yaml": "^2.8.1"
  }
}
