---
import type { UiConfig } from '../lib/config';
interface Props { title: string; ui: UiConfig; }
const { title, ui } = Astro.props;
---
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    <style>
      :root {
        --bg: #f4f2eb;
        --paper: #fffaf0;
        --ink: #17202a;
        --muted: #5f6b76;
        --line: #d7d0bf;
        --accent: #b34317;
        --accent-2: #0f5e6e;
        --ok: #2f7b4a;
        --warn: #8f5b0a;
        --high: #9f2d20;
      }
      * { box-sizing: border-box; }
      body {
        margin: 0;
        color: var(--ink);
        background:
          radial-gradient(circle at 8% 10%, rgba(179,67,23,0.08), transparent 35%),
          radial-gradient(circle at 90% 12%, rgba(15,94,110,0.08), transparent 40%),
          linear-gradient(180deg, #f7f4ec 0%, #f1ede2 100%);
        font-family: Georgia, 'Iowan Old Style', serif;
      }
      a { color: inherit; }
      .shell { max-width: 1200px; margin: 0 auto; padding: 1rem; }
      .masthead {
        border: 1px solid var(--line);
        background: color-mix(in srgb, var(--paper) 92%, white);
        border-radius: 16px;
        padding: 1rem 1.2rem;
        display: grid;
        gap: 0.5rem;
        box-shadow: 0 10px 30px rgba(23,32,42,0.05);
      }
      .brand { font-size: clamp(1.5rem, 2vw + 1rem, 2.4rem); line-height: 1; margin: 0; }
      .subtitle { color: var(--muted); margin: 0; font-size: 0.95rem; }
      nav ul { list-style: none; padding: 0; margin: 0.3rem 0 0; display: flex; gap: 0.5rem; flex-wrap: wrap; }
      nav a { display: inline-block; border: 1px solid var(--line); border-radius: 999px; padding: 0.35rem 0.8rem; text-decoration: none; background: #fff; }
      nav a:hover, nav a:focus-visible { border-color: var(--accent); outline: none; }
      main { margin-top: 1rem; }
      .panel {
        background: rgba(255,255,255,0.82);
        border: 1px solid var(--line);
        border-radius: 16px;
        padding: 1rem;
        backdrop-filter: blur(4px);
      }
      .grid { display: grid; gap: 1rem; }
      .toolbar { display: grid; gap: 0.75rem; grid-template-columns: repeat(auto-fit, minmax(140px, 1fr)); align-items: end; }
      .toolbar label { display: grid; gap: 0.3rem; font: 600 0.8rem/1.2 ui-sans-serif, system-ui, sans-serif; color: var(--muted); }
      .toolbar input, .toolbar select {
        border: 1px solid var(--line); border-radius: 10px; padding: 0.55rem 0.7rem; font: 400 0.95rem/1.2 ui-sans-serif, system-ui, sans-serif; background: #fff;
      }
      button {
        border: 1px solid var(--ink); background: var(--ink); color: white; border-radius: 10px; padding: 0.65rem 0.9rem; cursor: pointer; font-weight: 600;
      }
      button.secondary { background: #fff; color: var(--ink); border-color: var(--line); }
      .cards { display: grid; gap: 0.8rem; }
      .card {
        border: 1px solid var(--line); border-radius: 14px; background: white; padding: 0.9rem;
        transition: transform 120ms ease, box-shadow 120ms ease;
      }
      .card:hover { transform: translateY(-1px); box-shadow: 0 6px 18px rgba(0,0,0,0.06); }
      .meta { color: var(--muted); display: flex; gap: 0.6rem; flex-wrap: wrap; font: 500 0.78rem/1.2 ui-sans-serif, system-ui, sans-serif; }
      .title { margin: 0.35rem 0 0.4rem; font-size: 1.1rem; }
      .title a { text-decoration: none; }
      .title a:hover { text-decoration: underline; }
      .tags { display: flex; flex-wrap: wrap; gap: 0.35rem; margin-top: 0.5rem; }
      .tag { border: 1px solid var(--line); border-radius: 999px; padding: 0.15rem 0.5rem; font: 500 0.75rem/1 ui-sans-serif, system-ui, sans-serif; background: #fcfbf7; }
      .sev-high { border-color: rgba(159,45,32,.3); background: rgba(159,45,32,.05); }
      .sev-medium { border-color: rgba(143,91,10,.25); background: rgba(143,91,10,.05); }
      .sev-low { border-color: rgba(47,123,74,.25); background: rgba(47,123,74,.05); }
      pre.diff { white-space: pre-wrap; background: #14181d; color: #f2f0e9; border-radius: 12px; padding: 0.9rem; font-size: 0.8rem; overflow: auto; }
      .split { display: grid; gap: 1rem; }
      @media (min-width: 900px) { .split { grid-template-columns: 2fr 1fr; } }
      .muted { color: var(--muted); }
      .stat-list { display: grid; gap: 0.6rem; }
      .stat { display: flex; justify-content: space-between; gap: 1rem; border-bottom: 1px solid var(--line); padding-bottom: 0.35rem; }
      .fade-in { animation: fadeIn .25s ease; }
      @keyframes fadeIn { from { opacity: 0; transform: translateY(4px); } to { opacity: 1; transform: translateY(0); } }
      @media (prefers-reduced-motion: reduce) { .fade-in, .card { animation: none; transition: none; } }
    </style>
  </head>
  <body>
    <div class="shell">
      <header class="masthead">
        <div>
          <h1 class="brand">{ui.brand.title}</h1>
          <p class="subtitle">{ui.brand.subtitle}</p>
        </div>
        <nav aria-label="Primary">
          <ul>
            {ui.pages.map((p) => (
              <li><a href={p.path}>{p.label}</a></li>
            ))}
          </ul>
        </nav>
      </header>
      <main><slot /></main>
    </div>
  </body>
</html>
